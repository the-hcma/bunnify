[Unit]
Description=Bunnify - Smart Bookmark Manager
After=network.target
StartLimitIntervalSec=100
StartLimitBurst=5

[Service]
Type=simple
# Assumes Bunnify is located in ~/work/ai/bunnify
# Adjust the path below if your repository is in a different location
WorkingDirectory=@@REPO_DIR@@
ExecStart=@@REPO_DIR@@/bunnify-server --foreground --listen-all --port 8001 --bookmarks @@REPO_DIR@@/bunnify.json
Restart=always
RestartSec=5
StandardOutput=append:%h/scratch/bunnify/bunnify.log
StandardError=append:%h/scratch/bunnify/bunnify.log
ExecStartPost=/usr/bin/curl --silent --fail --max-time 5 --retry 12 --retry-delay 1 --retry-connrefused http://127.0.0.1:8001/health

[Install]
WantedBy=default.target
