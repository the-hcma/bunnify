#!/bin/bash

# Bunnify Server Startup Script

# Function to display help
show_help() {
    cat << EOF
🐰 Bunnify - Smart Bookmark Manager

USAGE:
    ./bunnify-server [OPTIONS]

DESCRIPTION:
    Starts the Bunnify Django development server with file watching for
    automatic bookmark reloading. The server runs on port 8000, accessible via:
    - http://127.0.0.1:8000 (IPv4)
    - http://[::1]:8000 (IPv6)
    - http://localhost:8000 (both)
    
    The server automatically checks if the database is properly initialized
    on startup. If needed, it will offer to initialize it for you.
    
    By default, the server daemonizes and runs in the background with logs
    sent to /tmp/bunnify.log. Use --console to run in foreground mode with
    console output (useful for development/debugging).

OPTIONS:
    -h, --help
        Display this help message and exit

    -f, --bookmarks FILE
        Path to the bookmarks JSON file (REQUIRED)
        Default: ~/work/bunnify/bunnify.json
        The server will not start if this file does not exist.

    --foreground
        Run in the foreground instead of daemonizing.
        Useful for debugging or running in containers.
        Press Ctrl+C to stop the server.
        Default: disabled (runs in background)

     --console
         Enable console logging and run in foreground mode.
         Useful for debugging or interactive development.
         Press Ctrl+C to stop the server.
         Default: disabled (runs in background with file logging only)

     --listen-all
         Listen on all network interfaces (0.0.0.0 and [::]) instead of
         just localhost (127.0.0.1 and [::1]). This enables external access
         from other machines. Use only when you want the server accessible
         from the public network.
         Default: disabled (localhost only - secure for development)

    --log-level LEVEL
        Set the logging level. Valid levels are:
            DEBUG    - Detailed diagnostic information
            INFO     - General informational messages
            WARNING  - Warning messages (default)
            ERROR    - Error messages only
            CRITICAL - Critical errors only
        Default: WARNING

    --stop
        Stop the running Bunnify server and file watcher.
        Uses PID files to identify processes to stop.

    --pid-dir DIR
        Directory for PID and port files (default: script directory).
        Use a unique temp directory in tests/CI to avoid interfering
        with a concurrently running production server.

EXAMPLES:
    # Start with default settings (WARNING level, file logging only)
    ./bunnify-server

    # Start with custom bookmarks file
    ./bunnify-server -f /path/to/my-bookmarks.json
    ./bunnify-server --bookmarks ~/custom/bookmarks.json

    # Start with console output enabled
    ./bunnify-server --console

    # Start with DEBUG level logging
    ./bunnify-server --log-level DEBUG

    # Combine options
    ./bunnify-server -f ~/my-bookmarks.json --console --log-level INFO

    # Run in foreground (for debugging)
    ./bunnify-server --foreground

    # Stop the server
    ./bunnify-server --stop

LOGGING:
    Log file location: /tmp/bunnify.log
    Log format: [timestamp] [level] [PID:pid] [module:function:line] message
    Log rotation: 10MB max size, 5 backup files

CONFIGURATION:
    Bookmarks file: ~/work/bunnify/bunnify.json
    Database: SQLite (db.sqlite3)
    Port: 8000

STOPPING THE SERVER:
    To stop the server, use one of these methods:
        1. ./bunnify-server --stop  (recommended)
        2. Ctrl+C (if running in foreground mode)
        3. kill <server_pid>  (PID shown at startup)
        4. pkill -f "manage.py runserver"

EOF
    exit 0
}

# Get the directory where this script is located
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Change to the script directory
cd "$script_dir" || exit 1

# Ensure common binary paths are in PATH (needed for nohup/background processes)
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

# Find uv command
if command -v uv > /dev/null 2>&1; then
    uv_cmd="uv"
else
    echo "❌ Error: uv command not found"
    echo "   Please install uv: curl -LsSf https://astral.sh/uv/install.sh | sh"
    exit 1
fi

# PID/port file directory (overridable via --pid-dir for isolated test runs)
pid_dir="$script_dir"
pid_file="$pid_dir/.bunnify.pid"
watcher_pid_file="$pid_dir/.bunnify_watcher.pid"
port_file="$pid_dir/.bunnify.port"

# Cleanup function to stop all processes
cleanup() {
    local exit_code=${1:-0}
    echo ""
    echo "🛑 Shutting down Bunnify..."
    
    # Kill server process
    if [ -n "$server_pid" ] && is_running "$server_pid" 2>/dev/null; then
        echo "   Stopping server (PID: $server_pid)..."
        kill "$server_pid" 2>/dev/null
        sleep 1
        if is_running "$server_pid" 2>/dev/null; then
            kill -9 "$server_pid" 2>/dev/null
        fi
    fi
    
    # Kill watcher process
    if [ -n "$watcher_pid" ] && is_running "$watcher_pid" 2>/dev/null; then
        echo "   Stopping watcher (PID: $watcher_pid)..."
        kill "$watcher_pid" 2>/dev/null
    fi
    
    # Clean up PID files
    rm -f "$pid_file" "$watcher_pid_file" "$port_file"
    
    echo "✅ Bunnify stopped."
    exit "$exit_code"
}

# Cleanup function for startup interruption
cleanup_startup() {
    echo ""
    echo "⚠️  Startup interrupted, cleaning up..."
    
    # Kill any processes we may have started
    if [ -n "$server_pid" ]; then
        kill "$server_pid" 2>/dev/null
        kill -9 "$server_pid" 2>/dev/null
    fi
    if [ -n "$watcher_pid" ]; then
        kill "$watcher_pid" 2>/dev/null
    fi
    
    rm -f "$pid_file" "$watcher_pid_file"
    echo "❌ Startup aborted."
    exit 130
}

# Set up signal traps
trap 'cleanup_startup' INT TERM

# Default log settings
export BUNNIFY_LOG_LEVEL="WARNING"
export BUNNIFY_LOG_CONSOLE="false"

# Default bookmarks file
bookmarks_file="${HOME}/work/bunnify/bunnify.json"

# Flags
do_stop=false
foreground=false
listen_all=false
server_port="8000"
pid_dir_override=""

# Parse command line arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --stop)
            do_stop=true
            shift
            ;;
        --pid-dir)
            if [ -z "$2" ]; then
                echo "Error: --pid-dir requires a directory path"
                echo "Run './bunnify-server --help' for more information"
                exit 1
            fi
            pid_dir_override="$2"
            shift 2
            ;;
        --port)
            if [ -z "$2" ]; then
                echo "Error: --port requires a value"
                echo "Run './bunnify-server --help' for more information"
                exit 1
            fi
            server_port="$2"
            shift 2
            ;;
        --foreground)
            foreground=true
            shift
            ;;
        -h|--help)
            show_help
            ;;
        -f|--bookmarks)
            if [ -z "$2" ]; then
                echo "Error: --bookmarks requires a file path"
                echo "Run './bunnify-server --help' for more information"
                exit 1
            fi
            bookmarks_file="$2"
            shift 2
            ;;
        --console)
            export BUNNIFY_LOG_CONSOLE="true"
            foreground=true
            shift
            ;;
        --listen-all)
            listen_all=true
            shift
            ;;
        --log-level)
            if [ -z "$2" ]; then
                echo "Error: --log-level requires a value"
                echo "Valid levels: DEBUG, INFO, WARNING, ERROR, CRITICAL"
                echo "Run './bunnify-server --help' for more information"
                exit 1
            fi
            export BUNNIFY_LOG_LEVEL="$2"
            shift 2
            ;;
        --log-file)
            if [ -z "$2" ]; then
                echo "Error: --log-file requires a file path"
                echo "Run './bunnify-server --help' for more information"
                exit 1
            fi
            export BUNNIFY_LOG_FILE="$2"
            shift 2
            ;;
        *)
            echo "Error: Unknown option: $1"
            echo "Run './bunnify-server --help' for usage information"
            exit 1
            ;;
    esac
done

# Apply --pid-dir override now that all args are parsed
if [ -n "$pid_dir_override" ]; then
    pid_dir="$pid_dir_override"
    pid_file="$pid_dir/.bunnify.pid"
    watcher_pid_file="$pid_dir/.bunnify_watcher.pid"
    port_file="$pid_dir/.bunnify.port"
fi

# If server_port is 0, ask the OS for a free ephemeral port, then hand that fixed port to Django.
# We close the socket immediately so Django can bind to it; there is a brief TOCTOU window
# but this is acceptable for local development and CI.
if [ "$server_port" = "0" ]; then
    server_port=$($uv_cmd run python -c 'import socket; s=socket.socket(); s.bind(("", 0)); print(s.getsockname()[1]); s.close()')
    echo "$server_port" > "$port_file"
fi

# Function to check if process is running
is_running() {
    local pid=$1
    if [ -z "$pid" ]; then
        return 1
    fi
    if ps -p "$pid" > /dev/null 2>&1; then
        return 0
    else
        return 1
    fi
}

# Function to check if port is in use
is_port_in_use() {
    lsof -ti:"$server_port" > /dev/null 2>&1
}
# Function to check if process is Bunnify
is_bunnify_process() {
    local pid=$1
    if [ -z "$pid" ]; then
        return 1
    fi
    # Check if the process command line contains 'manage.py' and is in our directory
    ps -p "$pid" -o command= 2>/dev/null | grep -q "manage.py"
}

# Function to stop the server (used by ./bunnify-server stop)
do_stop() {
    local found_process=false
    local server_pid
    local watcher_pid
    local port_pid
    
    if [ -f "$pid_file" ]; then
        server_pid=$(cat "$pid_file")
        if is_running "$server_pid"; then
            echo "🛑 Stopping server (PID: $server_pid)..."
            kill "$server_pid" 2>/dev/null
            sleep 1
            if is_running "$server_pid"; then
                kill -9 "$server_pid" 2>/dev/null
            fi
            found_process=true
        fi
        rm -f "$pid_file" "$port_file"
    fi
    
    if [ -f "$watcher_pid_file" ]; then
        watcher_pid=$(cat "$watcher_pid_file")
        if is_running "$watcher_pid"; then
            echo "🛑 Stopping file watcher (PID: $watcher_pid)..."
            kill "$watcher_pid" 2>/dev/null
            found_process=true
        fi
        rm -f "$watcher_pid_file" "$port_file"
    fi
    
    # Also check for any orphaned processes on the target port
    local check_port
    if [ -f "$port_file" ]; then
        check_port=$(cat "$port_file" 2>/dev/null || true)
    else
        check_port="$server_port"
    fi
    if [ -n "$check_port" ] && [ "$check_port" != "0" ]; then
        if lsof -ti:"$check_port" > /dev/null 2>&1; then
            port_pid=$(lsof -ti:"$check_port" 2>/dev/null | head -1)
            if [ -n "$port_pid" ] && is_bunnify_process "$port_pid"; then
                echo "🛑 Stopping orphaned Bunnify process (PID: $port_pid)..."
                kill "$port_pid" 2>/dev/null
                sleep 1
                if is_running "$port_pid"; then
                    kill -9 "$port_pid" 2>/dev/null
                fi
                found_process=true
            fi
        fi
    fi
    
    if $found_process; then
        echo "✅ Bunnify stopped."
    else
        echo "ℹ️  Bunnify was not running."
    fi
    exit 0
}

# Handle stop command now that functions are defined
if $do_stop; then
    do_stop
fi

# Function to stop existing server
stop_server() {
    local server_pid
    local watcher_pid
    local port_pid
    local proc_cmd
    
    if [ -f "$pid_file" ]; then
        server_pid=$(cat "$pid_file")
        if is_running "$server_pid"; then
            echo "🛑 Stopping existing server (PID: $server_pid)..."
            kill "$server_pid" 2>/dev/null
            sleep 2
            if is_running "$server_pid"; then
                kill -9 "$server_pid" 2>/dev/null
            fi
        fi
        rm -f "$pid_file"
    fi
    
    if [ -f "$watcher_pid_file" ]; then
        watcher_pid=$(cat "$watcher_pid_file")
        if is_running "$watcher_pid"; then
            echo "🛑 Stopping file watcher (PID: $watcher_pid)..."
            kill "$watcher_pid" 2>/dev/null
        fi
        rm -f "$watcher_pid_file"
    fi
    
    # Check if port is still in use
    local check_port
    if [ -f "$port_file" ]; then
        check_port=$(cat "$port_file" 2>/dev/null || true)
    else
        check_port="$server_port"
    fi
    if [ -n "$check_port" ] && [ "$check_port" != "0" ] && lsof -ti:"$check_port" > /dev/null 2>/dev/null; then
        port_pid=$(lsof -ti:"$check_port" 2>/dev/null | head -1)
        if [ -n "$port_pid" ]; then
            proc_cmd=$(ps -p "$port_pid" -o command= 2>/dev/null)
            
            # Check if it's a Bunnify process
            if is_bunnify_process "$port_pid"; then
                echo "🛑 Port $check_port still in use by Bunnify process (PID: $port_pid), killing..."
                kill -9 "$port_pid" 2>/dev/null
                sleep 1
            else
                echo "⚠️  WARNING: Port $check_port is in use by a non-Bunnify process!"
                echo "   PID: $port_pid"
                echo "   Command: $proc_cmd"
                echo ""
                echo -n "Kill this process and continue? (y/N): "
                read -r response
                if [[ "$response" =~ ^[Yy]$ ]]; then
                    echo "🛑 Killing process $port_pid..."
                    kill -9 "$port_pid" 2>/dev/null
                    sleep 1
                else
                    echo "❌ Aborted. Please free port 8000 manually and try again."
                    exit 1
                fi
            fi
        fi
    fi
}

# Check if server is already running
if [ -f "$pid_file" ]; then
    server_pid=$(cat "$pid_file")
    if is_running "$server_pid"; then
        echo "🐰 Bunnify is already running (PID: $server_pid)"
        echo "🔄 Stopping and restarting..."
        stop_server
        # Wait for port to be released
        for _ in {1..10}; do
            if ! is_port_in_use; then
                break
            fi
            sleep 0.5
        done
    else
        echo "🧹 Cleaning up stale PID file..."
        rm -f "$pid_file" "$watcher_pid_file" "$port_file"
    fi
elif is_port_in_use; then
    port_pid=$(lsof -ti:8000 2>/dev/null | head -1)
    if is_bunnify_process "$port_pid"; then
        echo "⚠️  Port 8000 is in use by another Bunnify process"
        echo "🔄 Stopping existing process and starting fresh..."
        stop_server
    else
        proc_cmd=$(ps -p "$port_pid" -o command= 2>/dev/null)
        echo "⚠️  WARNING: Port 8000 is in use by a non-Bunnify process!"
        echo "   PID: $port_pid"
        echo "   Command: $proc_cmd"
        stop_server
    fi
fi

echo "🐰 Starting Bunnify server..."
echo "Directory: $script_dir"

# Show log location
if [ "$BUNNIFY_LOG_CONSOLE" = "true" ]; then
    echo "📝 Logging: Console output (foreground mode)"
else
    echo "📝 Logging: /tmp/bunnify.log"
fi
echo ""

# Determine server binding address
if $listen_all; then
    # Get the actual public IP address for display
    public_ip=$(hostname -I 2>/dev/null | awk '{print $1}')
    if [ -z "$public_ip" ]; then
        # Fallback to localhost if we can't determine IP
        public_ip="127.0.0.1"
    fi
    # Listen on all IPv4 addresses (will handle IPv6 if OS configured to map IPv4 to v6)
    server_address="$public_ip:$server_port"
else
    # Listen on localhost IPv4 only (most secure default)
    server_address="127.0.0.1:$server_port"
fi

# Expand tilde in bookmarks file path if present
bookmarks_file="${bookmarks_file/#\~/$HOME}"

# Check database readiness (always run before operations that need the database)
echo "🔍 Checking database..."
db_check_output=$($uv_cmd run python manage.py check_database 2>&1)
db_check_exit=$?

if [ $db_check_exit -eq 0 ]; then
    # Database is ready - show brief status if console is enabled
    if [ "$BUNNIFY_LOG_CONSOLE" = "true" ]; then
        echo "$db_check_output" | head -5
    fi
else
    # Database has issues - offer to fix
    echo "❌ Database is not ready!"
    echo ""
    echo "$db_check_output"
    echo ""
    echo -n "Would you like me to initialize the database now? (y/N): "
    read -r response
    if [[ "$response" =~ ^[Yy]$ ]]; then
        echo ""
        $uv_cmd run python manage.py check_database --fix
        fix_exit=$?
        if [ $fix_exit -ne 0 ]; then
            exit 1
        fi
    else
        echo "Aborted. Please initialize the database manually with:"
        echo "  uv run python manage.py migrate"
        exit 1
    fi
fi
echo ""

# Check bookmarks file exists (hard requirement)
if [ ! -f "$bookmarks_file" ]; then
    echo "❌ Error: Bookmarks file not found: $bookmarks_file"
    echo ""
    echo "The bookmarks file is required to start the server."
    echo "Please provide a valid bookmarks file using:"
    echo "  ./bunnify-server --bookmarks /path/to/bunnify.json"
    echo ""
    exit 1
fi

# Load bookmarks
bookmarks_abs=$(cd "$(dirname "$bookmarks_file")" && pwd)/$(basename "$bookmarks_file")
echo "📖 Loading bookmarks from: $bookmarks_abs"

# Load bookmarks initially (capture output to check for errors)
load_output=$($uv_cmd run python manage.py load_bookmarks --file "$bookmarks_file" 2>&1)
load_exit=$?

if [ $load_exit -eq 0 ]; then
    # Extract count from output (looks for "Successfully loaded X bookmarks")
    bookmark_count=$(echo "$load_output" | grep -o "loaded [0-9]\+ bookmarks" | grep -o "[0-9]\+")
    if [ -n "$bookmark_count" ]; then
        echo "✓ Loaded $bookmark_count bookmarks"
    else
        echo "✓ Bookmarks loaded"
    fi
else
    echo "❌ Error: Failed to load bookmarks"
    echo ""
    echo "$load_output"
    echo ""
    exit 1
fi
echo ""

if $foreground; then
    # Foreground mode: run directly with proper signal handling
    
    # Start the file watcher in the background
    $uv_cmd run python manage.py watch_bookmarks --file "$bookmarks_file" &
    watcher_pid=$!
    echo "$watcher_pid" > "$watcher_pid_file"
    
    # Give the watcher a moment to start
    sleep 1
    
    # Verify watcher started successfully (hard requirement)
    if ! is_running "$watcher_pid"; then
        echo "❌ Error: File watcher failed to start"
        echo ""
        echo "The file watcher is required for the server to function properly."
        rm -f "$watcher_pid_file"
        echo ""
        echo "Please check /tmp/bunnify.log for details."
        exit 1
    fi
    
    # Track the Django server PID (will be set when we start it)
    django_pid=""
    
    # Set up cleanup trap for foreground mode
    cleanup_foreground() {
        local exit_code=${1:-0}
        echo ""
        echo "🛑 Shutting down Bunnify..."
        
        # Kill Django server if running
        if [ -n "$django_pid" ] && is_running "$django_pid"; then
            echo "   Stopping Django server (PID: $django_pid)..."
            kill "$django_pid" 2>/dev/null
            # Give it a moment to shut down gracefully
            sleep 1
            if is_running "$django_pid"; then
                kill -9 "$django_pid" 2>/dev/null
            fi
        fi
        
        # Kill watcher
        if [ -n "$watcher_pid" ] && is_running "$watcher_pid"; then
            echo "   Stopping file watcher (PID: $watcher_pid)..."
            kill "$watcher_pid" 2>/dev/null
        fi
        
        # Clean up any processes still using the target port
        if is_port_in_use; then
            local port_pid
            port_pid=$(lsof -ti:"$server_port" 2>/dev/null | head -1)
            if [ -n "$port_pid" ]; then
                kill "$port_pid" 2>/dev/null
            fi
        fi
        
        # Clean up PID files
        rm -f "$pid_file" "$watcher_pid_file"
        
        echo "✅ Bunnify stopped."
        exit "$exit_code"
    }
    
    # Trap multiple signals for proper cleanup
    trap 'cleanup_foreground 130' INT      # Ctrl+C
    trap 'cleanup_foreground 143' TERM     # kill command
    trap 'cleanup_foreground 129' HUP      # terminal closed
    
    echo "✅ Bunnify server starting in foreground mode..."
    echo "   Watcher PID: $watcher_pid"
    echo "   URLs:"
    if $listen_all; then
        echo "     - http://$public_ip:$server_port/ (public IP)"
        echo "     - http://127.0.0.1:$server_port/ (IPv4 localhost)"
        echo "     - http://[::1]:$server_port/ (IPv6 localhost)"
        echo "     - http://localhost:$server_port/ (localhost auto)"
    else
        echo "     - http://127.0.0.1:$server_port/ (IPv4)"
        echo "     - http://[::1]:$server_port/ (IPv6)"
        echo "     - http://localhost:$server_port/ (auto)"
    fi
    echo "   Log level: $BUNNIFY_LOG_LEVEL"
    echo ""
    echo "Press Ctrl+C to stop the server"
    echo ""
    
    # Run Django server in foreground (this blocks)
    $uv_cmd run python manage.py runserver "$server_address" &
    django_pid=$!
    
    # Give Django a moment to print its startup messages
    sleep 2
    
    # Show security warning after Django's own warning message
    if $listen_all; then
        echo ""
        echo "╔══════════════════════════════════════════════════════════════╗"
        echo "║                                                              ║"
        echo "║                     SECURITY WARNING                         ║"
        echo "║                                                              ║"
        echo "║     Server is listening on ALL network interfaces            ║"
        echo "║     This is a DEVELOPMENT server, NOT for production!        ║"
        echo "║                                                              ║"
        echo "╚══════════════════════════════════════════════════════════════╝"
        echo ""
        echo "   Public access: http://$public_ip:8000/"
        echo ""
    fi
    
    # Wait for Django to exit (this makes the script interruptible)
    wait $django_pid
    django_exit_code=$?
    
    # If we get here, the server exited on its own
    cleanup_foreground $django_exit_code
else
    # Background mode (default): daemonize the processes
    
    # Start the file watcher in the background (daemonized)
    nohup $uv_cmd run python manage.py watch_bookmarks --file "$bookmarks_file" > /dev/null 2>&1 &
    watcher_pid=$!
    echo "$watcher_pid" > "$watcher_pid_file"
    
    # Start the Django development server in the background (daemonized)
    # Capture output to temp file for debugging
    startup_log="/tmp/bunnify_startup.log"
    nohup $uv_cmd run python manage.py runserver "$server_address" > "$startup_log" 2>&1 &
    server_pid=$!
    echo "$server_pid" > "$pid_file"
    
    # Wait for processes to start (uv spawns python which takes a moment)
    sleep 3
    
    # The PID we captured is uv's PID, but we need to check if port is now in use
    # as that indicates the server actually started successfully
    if ! is_port_in_use; then
        echo "❌ Failed to start Django server"
        rm -f "$pid_file" "$watcher_pid_file"
        # Show startup log if it exists
        if [ -f "$startup_log" ] && [ -s "$startup_log" ]; then
            echo "   Startup output:"
            head -20 "$startup_log" | sed 's/^/   /'
        else
            echo "   Check /tmp/bunnify.log for details"
        fi
        exit 1
    fi

    # Update PID file with actual Django process PID
    actual_server_pid=$(lsof -ti:"$server_port" 2>/dev/null | head -1)
    if [ -n "$actual_server_pid" ]; then
        server_pid=$actual_server_pid
        echo "$server_pid" > "$pid_file"
    fi
    
    # Check if file watcher started successfully (hard requirement)
    if ! is_running "$watcher_pid"; then
        echo "❌ Error: File watcher failed to start"
        echo ""
        echo "The file watcher is required for the server to function properly."
        echo "It monitors bookmarks for changes and reloads them automatically."
        echo ""
        # Kill the server since we can't proceed
        echo "🛑 Stopping server due to watcher failure..."
        kill "$server_pid" 2>/dev/null
        sleep 1
        if is_running "$server_pid"; then
            kill -9 "$server_pid" 2>/dev/null
        fi
        rm -f "$pid_file" "$watcher_pid_file"
        echo ""
        echo "Please check /tmp/bunnify.log for details."
        exit 1
    fi
    
    # Clear the startup trap now that we're done
    trap - INT TERM
    
    echo "✅ Bunnify server started successfully!"
    echo "   Server PID: $server_pid"
    echo "   Watcher PID: $watcher_pid"
    echo "   URLs:"
    if $listen_all; then
        echo "     - http://$public_ip:$server_port/ (public IP)"
        echo "     - http://127.0.0.1:$server_port/ (IPv4 localhost)"
        echo "     - http://[::1]:$server_port/ (IPv6 localhost)"
        echo "     - http://localhost:$server_port/ (localhost auto)"
    else
        echo "     - http://127.0.0.1:$server_port/ (IPv4)"
        echo "     - http://[::1]:$server_port/ (IPv6)"
        echo "     - http://localhost:$server_port/ (auto)"
    fi
    echo "   Log file: /tmp/bunnify.log"
    echo "   Log level: $BUNNIFY_LOG_LEVEL"
    echo ""
    echo "To stop the server, run: ./bunnify-server --stop"
fi
